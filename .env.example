# iProjectMaster — Hire a Writer
# Copy this to .env.local and fill in your values

# ─── DATABASE ────────────────────────────────────────────────
# PostgreSQL connection string
# Local:   postgresql://user:password@localhost:5432/ipm_writer
# Railway: Get from Railway dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/ipm_writer"

# ─── NEXTAUTH ────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# ─── PAYSTACK ────────────────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── FILE STORAGE (Cloudinary) ───────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# ─── EMAIL (Resend) ───────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="iProjectMaster <noreply@iprojectmaster.com>"

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="iProjectMaster"
